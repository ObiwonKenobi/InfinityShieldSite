# Copy this file to .env and fill in your values
# (Never commit .env to git)

# Your Gmail address used to send alerts
SMTP_USER=you@gmail.com

# Gmail App Password (NOT your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
# Requires 2FA to be enabled on your Google account
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Email address to receive alerts (can be same as SMTP_USER)
NOTIFY_EMAIL=you@gmail.com

# How often to check for new jobs (seconds). Default: 3600 (1 hour)
CHECK_INTERVAL_SECONDS=3600

# SMTP settings (defaults work for Gmail — change only if using another provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
